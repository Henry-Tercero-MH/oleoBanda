-- ('CHEQUE',        'Cheque',                   TRUE),
-- ('CREDITO',       'Crédito (Cuenta)',         FALSE);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 4: PRODUCTOS E INVENTARIO                                       ║
-- ║  Núcleo del sistema — unidad base + presentaciones                      ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE producto (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    -- Identificación
    codigo_interno          VARCHAR(30)     NOT NULL UNIQUE,
    codigo_barras           VARCHAR(50),
    nombre                  VARCHAR(250)    NOT NULL,
    descripcion             TEXT,
    -- Clasificación
    categoria_id            INT             NOT NULL,
    marca_id                INT,
    -- Unidad base: la unidad atómica de almacenamiento
    unidad_medida_id        INT             NOT NULL,
    -- Impuesto
    tipo_impuesto_id        INT             NOT NULL,
    -- Stock
    stock_actual            DECIMAL(14,4)   NOT NULL DEFAULT 0,
    stock_minimo            DECIMAL(14,4)   NOT NULL DEFAULT 0,
    stock_maximo            DECIMAL(14,4)   NOT NULL DEFAULT 0,
    -- Costeo
    costo_promedio          DECIMAL(12,4)   NOT NULL DEFAULT 0,
    ultimo_costo            DECIMAL(12,4)   NOT NULL DEFAULT 0,
    -- Características
    ubicacion_bodega        VARCHAR(50),
    peso_kg                 DECIMAL(10,4),
    es_servicio             BOOLEAN         NOT NULL DEFAULT FALSE,
    permite_decimal         BOOLEAN         NOT NULL DEFAULT FALSE,
    maneja_lote             BOOLEAN         NOT NULL DEFAULT FALSE,
    maneja_vencimiento      BOOLEAN         NOT NULL DEFAULT FALSE,
    -- Control
    imagen_path             VARCHAR(500),
    notas_internas          TEXT,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_producto_categoria
        FOREIGN KEY (categoria_id) REFERENCES categoria(id),
    CONSTRAINT fk_producto_marca
        FOREIGN KEY (marca_id) REFERENCES marca(id),
    CONSTRAINT fk_producto_unidad
        FOREIGN KEY (unidad_medida_id) REFERENCES unidad_medida(id),
    CONSTRAINT fk_producto_impuesto
        FOREIGN KEY (tipo_impuesto_id) REFERENCES tipo_impuesto(id),
    CONSTRAINT chk_stock_actual
        CHECK (stock_actual >= 0)
);

CREATE INDEX idx_producto_codigo ON producto(codigo_interno);
CREATE INDEX idx_producto_barras ON producto(codigo_barras);
CREATE INDEX idx_producto_nombre ON producto(nombre);
CREATE INDEX idx_producto_categoria ON producto(categoria_id);

-- Presentaciones: formas de compra/venta sobre la misma unidad base
-- EJEMPLO: Producto "Clavos 2in" unidad_base=UND
--   Presentación "Unidad"  factor=1       precio=Q0.15
--   Presentación "Libra"   factor=100     precio=Q12.00
--   Presentación "Caja"    factor=500     precio=Q55.00
CREATE TABLE presentacion (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    producto_id             INT             NOT NULL,
    nombre                  VARCHAR(100)    NOT NULL,
    -- Cuántas unidades base contiene esta presentación
    factor_conversion       DECIMAL(14,4)   NOT NULL DEFAULT 1,
    -- Precios de venta
    precio_venta            DECIMAL(12,2)   NOT NULL,
    precio_venta_2          DECIMAL(12,2),
    precio_venta_3          DECIMAL(12,2),
    precio_mayoreo          DECIMAL(12,2),
    -- Cantidad mínima para precio mayoreo
    cantidad_mayoreo        DECIMAL(14,4)   NOT NULL DEFAULT 0,
    -- Código de barras específico de la presentación
    codigo_barras           VARCHAR(50),
    -- Control
    es_predeterminada       BOOLEAN         NOT NULL DEFAULT FALSE,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_presentacion_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT chk_factor_positivo
        CHECK (factor_conversion > 0),
    CONSTRAINT chk_precio_positivo
        CHECK (precio_venta >= 0)
);

CREATE INDEX idx_presentacion_producto ON presentacion(producto_id);
CREATE INDEX idx_presentacion_barras ON presentacion(codigo_barras);

-- Lotes (para productos que manejan lote/vencimiento)
CREATE TABLE lote (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    producto_id             INT             NOT NULL,
    numero_lote             VARCHAR(50)     NOT NULL,
    fecha_vencimiento       DATE,
    stock_lote              DECIMAL(14,4)   NOT NULL DEFAULT 0,
    costo_unitario          DECIMAL(12,4)   NOT NULL DEFAULT 0,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_lote_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT uq_lote
        UNIQUE (producto_id, numero_lote)
);

-- Stock por bodega (si se manejan múltiples bodegas)
CREATE TABLE bodega (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    nombre                  VARCHAR(100)    NOT NULL,
    direccion               VARCHAR(250),
    responsable             VARCHAR(150),
    es_principal            BOOLEAN         NOT NULL DEFAULT FALSE,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_bodega_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id)
);

CREATE TABLE stock_bodega (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    producto_id             INT             NOT NULL,
    bodega_id               INT             NOT NULL,
    stock                   DECIMAL(14,4)   NOT NULL DEFAULT 0,
    stock_minimo            DECIMAL(14,4)   NOT NULL DEFAULT 0,
    ubicacion               VARCHAR(50),
    updated_at              TIMESTAMP,
    CONSTRAINT fk_sb_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_sb_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT uq_stock_bodega
        UNIQUE (producto_id, bodega_id),
    CONSTRAINT chk_stock_bodega
        CHECK (stock >= 0)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 5: TERCEROS (CLIENTES Y PROVEEDORES)                           ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE cliente (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    -- Datos fiscales (FEL)
    nit                     VARCHAR(15)     NOT NULL DEFAULT 'CF',
    cui                     VARCHAR(20),
    nombre                  VARCHAR(250)    NOT NULL DEFAULT 'CONSUMIDOR FINAL',
    direccion               VARCHAR(500)    NOT NULL DEFAULT 'CIUDAD',
    correo                  VARCHAR(150),
    telefono                VARCHAR(20),
    -- Crédito
    tiene_credito           BOOLEAN         NOT NULL DEFAULT FALSE,
    limite_credito          DECIMAL(12,2)   NOT NULL DEFAULT 0,
    saldo_pendiente         DECIMAL(12,2)   NOT NULL DEFAULT 0,
    dias_credito            INT             NOT NULL DEFAULT 0,
    -- Descuento
    porcentaje_descuento    DECIMAL(5,2)    NOT NULL DEFAULT 0,
    lista_precio            INT             NOT NULL DEFAULT 1,
    -- Control
    notas                   TEXT,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

CREATE INDEX idx_cliente_nit ON cliente(nit);
CREATE INDEX idx_cliente_nombre ON cliente(nombre);

CREATE TABLE proveedor (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    nit                     VARCHAR(15)     NOT NULL,
    nombre                  VARCHAR(250)    NOT NULL,
    nombre_contacto         VARCHAR(150),
    direccion               VARCHAR(500),
    telefono                VARCHAR(20),
    correo                  VARCHAR(150),
    sitio_web               VARCHAR(250),
    -- Condiciones
    dias_credito            INT             NOT NULL DEFAULT 0,
    porcentaje_descuento    DECIMAL(5,2)    NOT NULL DEFAULT 0,
    notas                   TEXT,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

CREATE INDEX idx_proveedor_nit ON proveedor(nit);
CREATE INDEX idx_proveedor_nombre ON proveedor(nombre);

-- Relación proveedor ↔ producto (qué productos surte cada proveedor)
CREATE TABLE proveedor_producto (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    proveedor_id            INT             NOT NULL,
    producto_id             INT             NOT NULL,
    codigo_proveedor        VARCHAR(50),
    costo_referencia        DECIMAL(12,4)   NOT NULL DEFAULT 0,
    tiempo_entrega_dias     INT             NOT NULL DEFAULT 0,
    es_principal            BOOLEAN         NOT NULL DEFAULT FALSE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_pp_proveedor
        FOREIGN KEY (proveedor_id) REFERENCES proveedor(id),
    CONSTRAINT fk_pp_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT uq_proveedor_producto
        UNIQUE (proveedor_id, producto_id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 6: COMPRAS                                                      ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

-- Órdenes de compra (opcional, para control previo)
CREATE TABLE orden_compra (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    proveedor_id            INT             NOT NULL,
    bodega_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    numero_orden            VARCHAR(30)     NOT NULL UNIQUE,
    fecha                   DATE            NOT NULL,
    fecha_entrega_esperada  DATE,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'PENDIENTE',
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    impuesto                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total                   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_oc_proveedor
        FOREIGN KEY (proveedor_id) REFERENCES proveedor(id),
    CONSTRAINT fk_oc_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT fk_oc_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_oc_estado
        CHECK (estado IN ('PENDIENTE','APROBADA','PARCIAL','COMPLETADA','CANCELADA'))
);

CREATE TABLE orden_compra_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    orden_compra_id         INT             NOT NULL,
    producto_id             INT             NOT NULL,
    presentacion_id         INT             NOT NULL,
    cantidad_solicitada     DECIMAL(14,4)   NOT NULL,
    cantidad_recibida       DECIMAL(14,4)   NOT NULL DEFAULT 0,
    costo_unitario          DECIMAL(12,4)   NOT NULL,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_ocd_orden
        FOREIGN KEY (orden_compra_id) REFERENCES orden_compra(id),
    CONSTRAINT fk_ocd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_ocd_presentacion
        FOREIGN KEY (presentacion_id) REFERENCES presentacion(id)
);

-- Compras (ingreso real de mercadería)
CREATE TABLE compra (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    proveedor_id            INT             NOT NULL,
    bodega_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    orden_compra_id         INT,
    -- Documento del proveedor
    numero_documento        VARCHAR(50)     NOT NULL,
    serie_documento         VARCHAR(20),
    fecha_documento         DATE            NOT NULL,
    fecha_recepcion         DATE            NOT NULL,
    -- Montos
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    impuesto                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total                   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    -- Estado
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'REGISTRADA',
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_compra_proveedor
        FOREIGN KEY (proveedor_id) REFERENCES proveedor(id),
    CONSTRAINT fk_compra_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT fk_compra_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_compra_orden
        FOREIGN KEY (orden_compra_id) REFERENCES orden_compra(id),
    CONSTRAINT chk_compra_estado
        CHECK (estado IN ('REGISTRADA','APLICADA','ANULADA'))
);

CREATE INDEX idx_compra_proveedor ON compra(proveedor_id);
CREATE INDEX idx_compra_fecha ON compra(fecha_documento);

CREATE TABLE compra_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    compra_id               INT             NOT NULL,
    producto_id             INT             NOT NULL,
    presentacion_id         INT             NOT NULL,
    lote_id                 INT,
    -- Cantidad en presentación (lo que se compró)
    cantidad                DECIMAL(14,4)   NOT NULL,
    -- Cantidad convertida a unidad base (automático)
    cantidad_base           DECIMAL(14,4)   NOT NULL,
    -- Costos
    costo_unitario          DECIMAL(12,4)   NOT NULL,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_cd_compra
        FOREIGN KEY (compra_id) REFERENCES compra(id),
    CONSTRAINT fk_cd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_cd_presentacion
        FOREIGN KEY (presentacion_id) REFERENCES presentacion(id),
    CONSTRAINT fk_cd_lote
        FOREIGN KEY (lote_id) REFERENCES lote(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 7: VENTAS Y PUNTO DE VENTA                                     ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

-- Correlativo de documentos (control interno por tipo de DTE)
CREATE TABLE correlativo (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    tipo_documento          VARCHAR(30)     NOT NULL,
    serie                   VARCHAR(20)     NOT NULL,
    numero_actual           INT             NOT NULL DEFAULT 0,
    prefijo                 VARCHAR(10),
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_corr_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id),
    CONSTRAINT uq_correlativo
        UNIQUE (establecimiento_id, tipo_documento, serie)
);

-- Cotización (preventa)
CREATE TABLE cotizacion (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    cliente_id              INT,
    numero_cotizacion       VARCHAR(30)     NOT NULL,
    fecha                   DATE            NOT NULL,
    fecha_vencimiento       DATE,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    impuesto                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total                   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'VIGENTE',
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_cot_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id),
    CONSTRAINT fk_cot_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_cot_cliente
        FOREIGN KEY (cliente_id) REFERENCES cliente(id),
    CONSTRAINT chk_cot_estado
        CHECK (estado IN ('VIGENTE','CONVERTIDA','VENCIDA','CANCELADA'))
);

CREATE TABLE cotizacion_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    cotizacion_id           INT             NOT NULL,
    producto_id             INT             NOT NULL,
    presentacion_id         INT             NOT NULL,
    cantidad                DECIMAL(14,4)   NOT NULL,
    precio_unitario         DECIMAL(12,2)   NOT NULL,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_cotd_cotizacion
        FOREIGN KEY (cotizacion_id) REFERENCES cotizacion(id),
    CONSTRAINT fk_cotd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_cotd_presentacion
        FOREIGN KEY (presentacion_id) REFERENCES presentacion(id)
);

-- Ventas
CREATE TABLE venta (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    bodega_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    cliente_id              INT             NOT NULL,
    cotizacion_id           INT,
    -- Documento interno
    numero_venta            VARCHAR(30)     NOT NULL,
    tipo_documento          VARCHAR(30)     NOT NULL DEFAULT 'FACT',
    serie                   VARCHAR(20),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    -- FEL
    fel_uuid                VARCHAR(100),
    fel_numero              VARCHAR(50),
    fel_serie               VARCHAR(30),
    fel_fecha_certificacion TIMESTAMP,
    fel_xml_path            VARCHAR(500),
    fel_pdf_path            VARCHAR(500),
    fel_estado              VARCHAR(20)     DEFAULT 'PENDIENTE',
    -- Montos
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    impuesto                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total                   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    -- Estado
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'COMPLETADA',
    motivo_anulacion        VARCHAR(250),
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_venta_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id),
    CONSTRAINT fk_venta_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT fk_venta_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_venta_cliente
        FOREIGN KEY (cliente_id) REFERENCES cliente(id),
    CONSTRAINT fk_venta_cotizacion
        FOREIGN KEY (cotizacion_id) REFERENCES cotizacion(id),
    CONSTRAINT chk_venta_estado
        CHECK (estado IN ('COMPLETADA','ANULADA')),
    CONSTRAINT chk_fel_estado
        CHECK (fel_estado IN ('PENDIENTE','CERTIFICADA','ERROR','ANULADA'))
);

CREATE INDEX idx_venta_fecha ON venta(fecha);
CREATE INDEX idx_venta_cliente ON venta(cliente_id);
CREATE INDEX idx_venta_fel_uuid ON venta(fel_uuid);
CREATE INDEX idx_venta_numero ON venta(numero_venta);

CREATE TABLE venta_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    venta_id                INT             NOT NULL,
    producto_id             INT             NOT NULL,
    presentacion_id         INT             NOT NULL,
    lote_id                 INT,
    -- Cantidad en la presentación vendida
    cantidad                DECIMAL(14,4)   NOT NULL,
    -- Cantidad convertida a unidad base (automático)
    cantidad_base           DECIMAL(14,4)   NOT NULL,
    -- Precio y descuento
    precio_unitario         DECIMAL(12,2)   NOT NULL,
    descuento               DECIMAL(12,2)   NOT NULL DEFAULT 0,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    -- Costo al momento de la venta (para margen)
    costo_unitario_base     DECIMAL(12,4)   NOT NULL DEFAULT 0,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_vd_venta
        FOREIGN KEY (venta_id) REFERENCES venta(id),
    CONSTRAINT fk_vd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_vd_presentacion
        FOREIGN KEY (presentacion_id) REFERENCES presentacion(id),
    CONSTRAINT fk_vd_lote
        FOREIGN KEY (lote_id) REFERENCES lote(id)
);

CREATE INDEX idx_venta_detalle_producto ON venta_detalle(producto_id);

-- Pagos de venta (una venta puede tener múltiples formas de pago)
CREATE TABLE venta_pago (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    venta_id                INT             NOT NULL,
    metodo_pago_id          INT             NOT NULL,
    monto                   DECIMAL(12,2)   NOT NULL,
    referencia              VARCHAR(100),
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_vp_venta
        FOREIGN KEY (venta_id) REFERENCES venta(id),
    CONSTRAINT fk_vp_metodo
        FOREIGN KEY (metodo_pago_id) REFERENCES metodo_pago(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 8: NOTAS DE CRÉDITO Y DÉBITO                                   ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE nota_credito_debito (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    venta_id                INT             NOT NULL,
    establecimiento_id      INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    tipo                    VARCHAR(10)     NOT NULL,
    numero                  VARCHAR(30)     NOT NULL,
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    motivo                  VARCHAR(500)    NOT NULL,
    -- FEL
    fel_uuid                VARCHAR(100),
    fel_numero              VARCHAR(50),
    fel_serie               VARCHAR(30),
    fel_fecha_certificacion TIMESTAMP,
    fel_xml_path            VARCHAR(500),
    fel_estado              VARCHAR(20)     DEFAULT 'PENDIENTE',
    -- Montos
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    impuesto                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total                   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'ACTIVA',
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_ncd_venta
        FOREIGN KEY (venta_id) REFERENCES venta(id),
    CONSTRAINT fk_ncd_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id),
    CONSTRAINT fk_ncd_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_ncd_tipo
        CHECK (tipo IN ('NCRE','NDEB')),
    CONSTRAINT chk_ncd_estado
        CHECK (estado IN ('ACTIVA','ANULADA'))
);

CREATE TABLE nota_credito_debito_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    nota_id                 INT             NOT NULL,
    producto_id             INT             NOT NULL,
    presentacion_id         INT             NOT NULL,
    cantidad                DECIMAL(14,4)   NOT NULL,
    cantidad_base           DECIMAL(14,4)   NOT NULL,
    precio_unitario         DECIMAL(12,2)   NOT NULL,
    subtotal                DECIMAL(12,2)   NOT NULL DEFAULT 0,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_ncdd_nota
        FOREIGN KEY (nota_id) REFERENCES nota_credito_debito(id),
    CONSTRAINT fk_ncdd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_ncdd_presentacion
        FOREIGN KEY (presentacion_id) REFERENCES presentacion(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 9: MOVIMIENTOS DE STOCK (AUDITORÍA)                             ║
-- ║  Cada movimiento que afecte stock queda registrado aquí                 ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE movimiento_stock (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    producto_id             INT             NOT NULL,
    bodega_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    lote_id                 INT,
    -- Tipo de movimiento
    tipo                    VARCHAR(30)     NOT NULL,
    -- Cantidades (siempre en unidad base)
    cantidad                DECIMAL(14,4)   NOT NULL,
    stock_anterior          DECIMAL(14,4)   NOT NULL,
    stock_nuevo             DECIMAL(14,4)   NOT NULL,
    -- Costo al momento del movimiento
    costo_unitario          DECIMAL(12,4)   NOT NULL DEFAULT 0,
    -- Referencia al documento origen
    referencia_tipo         VARCHAR(30),
    referencia_id           INT,
    referencia_numero       VARCHAR(50),
    -- Detalle
    observacion             VARCHAR(500),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_ms_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id),
    CONSTRAINT fk_ms_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT fk_ms_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_ms_lote
        FOREIGN KEY (lote_id) REFERENCES lote(id),
    CONSTRAINT chk_ms_tipo
        CHECK (tipo IN (
            'COMPRA',
            'VENTA',
            'DEVOLUCION_COMPRA',
            'DEVOLUCION_VENTA',
            'AJUSTE_POSITIVO',
            'AJUSTE_NEGATIVO',
            'TRASLADO_ENTRADA',
            'TRASLADO_SALIDA',
            'MERMA',
            'INVENTARIO_FISICO',
            'INICIAL'
        ))
);

CREATE INDEX idx_ms_producto ON movimiento_stock(producto_id);
CREATE INDEX idx_ms_fecha ON movimiento_stock(fecha);
CREATE INDEX idx_ms_tipo ON movimiento_stock(tipo);
CREATE INDEX idx_ms_referencia ON movimiento_stock(referencia_tipo, referencia_id);

-- Traslados entre bodegas
CREATE TABLE traslado (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    bodega_origen_id        INT             NOT NULL,
    bodega_destino_id       INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    numero_traslado         VARCHAR(30)     NOT NULL,
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'PENDIENTE',
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_traslado_origen
        FOREIGN KEY (bodega_origen_id) REFERENCES bodega(id),
    CONSTRAINT fk_traslado_destino
        FOREIGN KEY (bodega_destino_id) REFERENCES bodega(id),
    CONSTRAINT fk_traslado_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_traslado_estado
        CHECK (estado IN ('PENDIENTE','EN_TRANSITO','COMPLETADO','CANCELADO'))
);

CREATE TABLE traslado_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    traslado_id             INT             NOT NULL,
    producto_id             INT             NOT NULL,
    cantidad_base           DECIMAL(14,4)   NOT NULL,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_td_traslado
        FOREIGN KEY (traslado_id) REFERENCES traslado(id),
    CONSTRAINT fk_td_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id)
);

-- Inventario físico (conteo real vs sistema)
CREATE TABLE inventario_fisico (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    bodega_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    numero                  VARCHAR(30)     NOT NULL,
    fecha                   DATE            NOT NULL,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'EN_CONTEO',
    notas                   TEXT,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_if_bodega
        FOREIGN KEY (bodega_id) REFERENCES bodega(id),
    CONSTRAINT fk_if_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_if_estado
        CHECK (estado IN ('EN_CONTEO','REVISION','APLICADO','CANCELADO'))
);

CREATE TABLE inventario_fisico_detalle (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    inventario_fisico_id    INT             NOT NULL,
    producto_id             INT             NOT NULL,
    stock_sistema           DECIMAL(14,4)   NOT NULL,
    stock_conteo            DECIMAL(14,4)   NOT NULL,
    diferencia              DECIMAL(14,4)   NOT NULL,
    costo_diferencia        DECIMAL(12,2)   NOT NULL DEFAULT 0,
    observacion             VARCHAR(250),
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_ifd_inventario
        FOREIGN KEY (inventario_fisico_id) REFERENCES inventario_fisico(id),
    CONSTRAINT fk_ifd_producto
        FOREIGN KEY (producto_id) REFERENCES producto(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 10: CAJA Y CORTES                                              ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE caja (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    nombre                  VARCHAR(50)     NOT NULL,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_caja_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id)
);

CREATE TABLE apertura_caja (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    caja_id                 INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    fecha_apertura          TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    fecha_cierre            TIMESTAMP,
    monto_apertura          DECIMAL(12,2)   NOT NULL DEFAULT 0,
    -- Montos calculados al cierre
    total_ventas_efectivo   DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total_ventas_tarjeta    DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total_ventas_otros      DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total_ingresos          DECIMAL(12,2)   NOT NULL DEFAULT 0,
    total_egresos           DECIMAL(12,2)   NOT NULL DEFAULT 0,
    monto_esperado          DECIMAL(12,2)   NOT NULL DEFAULT 0,
    monto_real              DECIMAL(12,2)   NOT NULL DEFAULT 0,
    diferencia              DECIMAL(12,2)   NOT NULL DEFAULT 0,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'ABIERTA',
    notas_cierre            TEXT,
    CONSTRAINT fk_ac_caja
        FOREIGN KEY (caja_id) REFERENCES caja(id),
    CONSTRAINT fk_ac_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_ac_estado
        CHECK (estado IN ('ABIERTA','CERRADA'))
);

-- Movimientos de caja (ingresos/egresos que no son ventas)
CREATE TABLE movimiento_caja (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    apertura_caja_id        INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    tipo                    VARCHAR(10)     NOT NULL,
    monto                   DECIMAL(12,2)   NOT NULL,
    concepto                VARCHAR(250)    NOT NULL,
    referencia              VARCHAR(100),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_mc_apertura
        FOREIGN KEY (apertura_caja_id) REFERENCES apertura_caja(id),
    CONSTRAINT fk_mc_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_mc_tipo
        CHECK (tipo IN ('INGRESO','EGRESO'))
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 11: CUENTAS POR COBRAR                                         ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE cuenta_por_cobrar (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    cliente_id              INT             NOT NULL,
    venta_id                INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    numero_documento        VARCHAR(30)     NOT NULL,
    fecha_emision           DATE            NOT NULL,
    fecha_vencimiento       DATE            NOT NULL,
    monto_original          DECIMAL(12,2)   NOT NULL,
    monto_pagado            DECIMAL(12,2)   NOT NULL DEFAULT 0,
    saldo                   DECIMAL(12,2)   NOT NULL,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'PENDIENTE',
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_cpc_cliente
        FOREIGN KEY (cliente_id) REFERENCES cliente(id),
    CONSTRAINT fk_cpc_venta
        FOREIGN KEY (venta_id) REFERENCES venta(id),
    CONSTRAINT fk_cpc_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_cpc_estado
        CHECK (estado IN ('PENDIENTE','PARCIAL','PAGADA','VENCIDA','CANCELADA'))
);

CREATE INDEX idx_cpc_cliente ON cuenta_por_cobrar(cliente_id);
CREATE INDEX idx_cpc_vencimiento ON cuenta_por_cobrar(fecha_vencimiento);

CREATE TABLE abono (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    cuenta_por_cobrar_id    INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    metodo_pago_id          INT             NOT NULL,
    monto                   DECIMAL(12,2)   NOT NULL,
    referencia              VARCHAR(100),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    notas                   VARCHAR(250),
    CONSTRAINT fk_abono_cuenta
        FOREIGN KEY (cuenta_por_cobrar_id) REFERENCES cuenta_por_cobrar(id),
    CONSTRAINT fk_abono_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_abono_metodo
        FOREIGN KEY (metodo_pago_id) REFERENCES metodo_pago(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 12: CUENTAS POR PAGAR (A PROVEEDORES)                          ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE cuenta_por_pagar (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    proveedor_id            INT             NOT NULL,
    compra_id               INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    numero_documento        VARCHAR(50)     NOT NULL,
    fecha_emision           DATE            NOT NULL,
    fecha_vencimiento       DATE            NOT NULL,
    monto_original          DECIMAL(12,2)   NOT NULL,
    monto_pagado            DECIMAL(12,2)   NOT NULL DEFAULT 0,
    saldo                   DECIMAL(12,2)   NOT NULL,
    estado                  VARCHAR(20)     NOT NULL DEFAULT 'PENDIENTE',
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_cpp_proveedor
        FOREIGN KEY (proveedor_id) REFERENCES proveedor(id),
    CONSTRAINT fk_cpp_compra
        FOREIGN KEY (compra_id) REFERENCES compra(id),
    CONSTRAINT fk_cpp_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT chk_cpp_estado
        CHECK (estado IN ('PENDIENTE','PARCIAL','PAGADA','VENCIDA','CANCELADA'))
);

CREATE INDEX idx_cpp_proveedor ON cuenta_por_pagar(proveedor_id);
CREATE INDEX idx_cpp_vencimiento ON cuenta_por_pagar(fecha_vencimiento);

CREATE TABLE pago_proveedor (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    cuenta_por_pagar_id     INT             NOT NULL,
    usuario_id              INT             NOT NULL,
    metodo_pago_id          INT             NOT NULL,
    monto                   DECIMAL(12,2)   NOT NULL,
    referencia              VARCHAR(100),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    notas                   VARCHAR(250),
    CONSTRAINT fk_pagop_cuenta
        FOREIGN KEY (cuenta_por_pagar_id) REFERENCES cuenta_por_pagar(id),
    CONSTRAINT fk_pagop_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id),
    CONSTRAINT fk_pagop_metodo
        FOREIGN KEY (metodo_pago_id) REFERENCES metodo_pago(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 13: LOG FEL (HISTORIAL DE COMUNICACIÓN CON EL CERTIFICADOR)    ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE fel_log (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    -- Referencia al documento (venta, nota de crédito, etc.)
    documento_tipo          VARCHAR(30)     NOT NULL,
    documento_id            INT             NOT NULL,
    -- Comunicación
    accion                  VARCHAR(30)     NOT NULL,
    request_json            TEXT,
    response_json           TEXT,
    http_status             INT,
    -- Resultado
    exitoso                 BOOLEAN         NOT NULL DEFAULT FALSE,
    uuid_dte                VARCHAR(100),
    numero_dte              VARCHAR(50),
    serie_dte               VARCHAR(30),
    mensaje_error           VARCHAR(500),
    -- Tiempo
    tiempo_respuesta_ms     INT,
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_fl_accion
        CHECK (accion IN (
            'CREAR_XML',
            'FIRMAR',
            'CERTIFICAR',
            'ANULAR',
            'CONSULTAR',
            'GENERAR_PDF'
        ))
);

CREATE INDEX idx_fl_documento ON fel_log(documento_tipo, documento_id);
CREATE INDEX idx_fl_uuid ON fel_log(uuid_dte);
CREATE INDEX idx_fl_fecha ON fel_log(fecha);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 14: AUDITORÍA GENERAL                                           ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE auditoria (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    usuario_id              INT,
    tabla                   VARCHAR(80)     NOT NULL,
    registro_id             INT             NOT NULL,
    accion                  VARCHAR(10)     NOT NULL,
    datos_anteriores        TEXT,
    datos_nuevos            TEXT,
    ip_address              VARCHAR(45),
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_aud_accion
        CHECK (accion IN ('INSERT','UPDATE','DELETE'))
);

CREATE INDEX idx_aud_tabla ON auditoria(tabla, registro_id);
CREATE INDEX idx_aud_usuario ON auditoria(usuario_id);
CREATE INDEX idx_aud_fecha ON auditoria(fecha);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 15: CONFIGURACIÓN Y PARÁMETROS DEL SISTEMA                     ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE configuracion (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    clave                   VARCHAR(80)     NOT NULL UNIQUE,
    valor                   VARCHAR(500)    NOT NULL,
    descripcion             VARCHAR(250),
    tipo_dato               VARCHAR(20)     NOT NULL DEFAULT 'STRING',
    modulo                  VARCHAR(50),
    editable                BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

