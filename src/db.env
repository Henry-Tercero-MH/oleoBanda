-- =============================================================================
-- SISTEMA DE GESTIÓN DE INVENTARIO + FACTURACIÓN FEL
-- Ferretería — Guatemala
-- Base de datos relacional normalizada (3FN)
-- Compatible: PostgreSQL, MySQL 8+, MariaDB 10.5+, SQL Server
-- Versión: 1.0
-- Fecha: Marzo 2026
-- =============================================================================
--
-- CONVENCIONES:
--   snake_case en tablas y columnas
--   PK: id INT autoincremental (adaptar SERIAL/IDENTITY según motor)
--   FK: {tabla_singular}_id
--   Timestamps: created_at, updated_at en todas las tablas
--   Soft delete: activo BOOLEAN donde aplica
--   Monetarios: DECIMAL(12,2)
--   Cantidades: DECIMAL(14,4) — soporta fracciones (metros, libras)
--   Porcentajes: DECIMAL(5,2)
--   Índices explícitos en FKs y campos de búsqueda frecuente
--
-- NOTAS DE PORTABILIDAD:
--   - Reemplazar BOOLEAN por BIT(1) en SQL Server
--   - Reemplazar SERIAL por IDENTITY(1,1) en SQL Server
--   - Reemplazar TEXT por NVARCHAR(MAX) en SQL Server
--   - Reemplazar TIMESTAMP por DATETIME2 en SQL Server
--   - En MySQL usar ENGINE=InnoDB para soporte transaccional
--
-- =============================================================================


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 1: CONFIGURACIÓN EMPRESARIAL                                    ║
-- ║  Datos fiscales del emisor, requeridos por el régimen FEL               ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE empresa (
    id                      INT PRIMARY KEY,
    nit                     VARCHAR(15)     NOT NULL,
    nombre_comercial        VARCHAR(250)    NOT NULL,
    razon_social            VARCHAR(250)    NOT NULL,
    direccion_fiscal        VARCHAR(500)    NOT NULL,
    municipio               VARCHAR(100)    NOT NULL,
    departamento            VARCHAR(100)    NOT NULL,
    codigo_postal           VARCHAR(10),
    telefono                VARCHAR(20),
    correo_electronico      VARCHAR(150),
    sitio_web               VARCHAR(250),
    regimen_tributario      VARCHAR(50)     NOT NULL,
    -- FEL: datos del certificador
    certificador_nombre     VARCHAR(100),
    certificador_nit        VARCHAR(15),
    fel_api_url             VARCHAR(500),
    fel_api_usuario         VARCHAR(100),
    fel_api_llave           VARCHAR(500),
    fel_ambiente            VARCHAR(20)     DEFAULT 'PRUEBAS',
    fel_firma_pfx_path      VARCHAR(500),
    fel_firma_alias         VARCHAR(100),
    fel_firma_password      VARCHAR(200),
    -- Personalización factura
    logo_path               VARCHAR(500),
    pie_factura             VARCHAR(500),
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

-- Establecimientos registrados ante SAT (una empresa puede tener varios)
CREATE TABLE establecimiento (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    empresa_id              INT             NOT NULL,
    codigo_establecimiento  VARCHAR(10)     NOT NULL,
    nombre                  VARCHAR(250)    NOT NULL,
    direccion               VARCHAR(500)    NOT NULL,
    municipio               VARCHAR(100)    NOT NULL,
    departamento            VARCHAR(100)    NOT NULL,
    telefono                VARCHAR(20),
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_establecimiento_empresa
        FOREIGN KEY (empresa_id) REFERENCES empresa(id),
    CONSTRAINT uq_establecimiento_codigo
        UNIQUE (empresa_id, codigo_establecimiento)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 2: USUARIOS, ROLES Y PERMISOS                                  ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

CREATE TABLE rol (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    nombre                  VARCHAR(50)     NOT NULL UNIQUE,
    descripcion             VARCHAR(250),
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

CREATE TABLE permiso (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    codigo                  VARCHAR(80)     NOT NULL UNIQUE,
    modulo                  VARCHAR(50)     NOT NULL,
    descripcion             VARCHAR(250),
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE rol_permiso (
    rol_id                  INT             NOT NULL,
    permiso_id              INT             NOT NULL,
    PRIMARY KEY (rol_id, permiso_id),
    CONSTRAINT fk_rp_rol
        FOREIGN KEY (rol_id) REFERENCES rol(id),
    CONSTRAINT fk_rp_permiso
        FOREIGN KEY (permiso_id) REFERENCES permiso(id)
);

CREATE TABLE usuario (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    establecimiento_id      INT             NOT NULL,
    rol_id                  INT             NOT NULL,
    username                VARCHAR(50)     NOT NULL UNIQUE,
    password_hash           VARCHAR(255)    NOT NULL,
    nombre_completo         VARCHAR(150)    NOT NULL,
    correo                  VARCHAR(150),
    telefono                VARCHAR(20),
    ultimo_acceso           TIMESTAMP,
    intentos_fallidos       INT             NOT NULL DEFAULT 0,
    bloqueado               BOOLEAN         NOT NULL DEFAULT FALSE,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_usuario_establecimiento
        FOREIGN KEY (establecimiento_id) REFERENCES establecimiento(id),
    CONSTRAINT fk_usuario_rol
        FOREIGN KEY (rol_id) REFERENCES rol(id)
);

CREATE INDEX idx_usuario_username ON usuario(username);

-- Bitácora de accesos
CREATE TABLE sesion_log (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    usuario_id              INT             NOT NULL,
    ip_address              VARCHAR(45),
    user_agent              VARCHAR(500),
    accion                  VARCHAR(20)     NOT NULL,
    fecha                   TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_sesion_usuario
        FOREIGN KEY (usuario_id) REFERENCES usuario(id)
);


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  MÓDULO 3: CATÁLOGOS BASE                                               ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

-- Categorías jerárquicas (autorreferenciada para N niveles)
CREATE TABLE categoria (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    categoria_padre_id      INT,
    nombre                  VARCHAR(100)    NOT NULL,
    descripcion             VARCHAR(250),
    nivel                   INT             NOT NULL DEFAULT 1,
    orden                   INT             NOT NULL DEFAULT 0,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP,
    CONSTRAINT fk_categoria_padre
        FOREIGN KEY (categoria_padre_id) REFERENCES categoria(id)
);

CREATE INDEX idx_categoria_padre ON categoria(categoria_padre_id);

-- Marcas
CREATE TABLE marca (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    nombre                  VARCHAR(100)    NOT NULL UNIQUE,
    activo                  BOOLEAN         NOT NULL DEFAULT TRUE,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMP
);

-- Unidades de medida base (catálogo centralizado)
CREATE TABLE unidad_medida (
    id                      INT PRIMARY KEY AUTO_INCREMENT,
    codigo                  VARCHAR(10)     NOT NULL UNIQUE,
    nombre                  VARCHAR(50)     NOT NULL,
    tipo                    VARCHAR(30)     NOT NULL,
    created_at              TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP
);

