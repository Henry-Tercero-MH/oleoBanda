-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  VISTAS ÚTILES                                                          ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝

-- Vista: Productos con stock y presentación predeterminada
CREATE VIEW v_producto_stock AS
SELECT
    p.id,
    p.codigo_interno,
    p.nombre,
    c.nombre                AS categoria,
    m.nombre                AS marca,
    um.codigo               AS unidad_base,
    um.nombre               AS unidad_base_nombre,
    p.stock_actual,
    p.stock_minimo,
    p.costo_promedio,
    pr.nombre               AS presentacion_default,
    pr.precio_venta         AS precio_default,
    pr.factor_conversion    AS factor_default,
    CASE
        WHEN p.stock_actual <= 0 THEN 'SIN_STOCK'
        WHEN p.stock_actual <= p.stock_minimo THEN 'STOCK_BAJO'
        ELSE 'DISPONIBLE'
    END                     AS estado_stock,
    p.activo
FROM producto p
    JOIN categoria c        ON c.id = p.categoria_id
    LEFT JOIN marca m       ON m.id = p.marca_id
    JOIN unidad_medida um   ON um.id = p.unidad_medida_id
    LEFT JOIN presentacion pr ON pr.producto_id = p.id AND pr.es_predeterminada = TRUE;

-- Vista: Ventas del día con datos FEL
CREATE VIEW v_ventas_dia AS
SELECT
    v.id,
    v.numero_venta,
    v.fecha,
    cl.nit                  AS cliente_nit,
    cl.nombre               AS cliente_nombre,
    v.total,
    v.fel_uuid,
    v.fel_numero,
    v.fel_estado,
    v.estado,
    u.nombre_completo       AS vendedor
FROM venta v
    JOIN cliente cl         ON cl.id = v.cliente_id
    JOIN usuario u          ON u.id = v.usuario_id
WHERE DATE(v.fecha) = CURRENT_DATE;

-- Vista: Productos bajo stock mínimo
CREATE VIEW v_stock_bajo AS
SELECT
    p.id,
    p.codigo_interno,
    p.nombre,
    c.nombre                AS categoria,
    um.codigo               AS unidad,
    p.stock_actual,
    p.stock_minimo,
    (p.stock_minimo - p.stock_actual) AS cantidad_faltante,
    prov.nombre             AS proveedor_principal
FROM producto p
    JOIN categoria c        ON c.id = p.categoria_id
    JOIN unidad_medida um   ON um.id = p.unidad_medida_id
    LEFT JOIN proveedor_producto pp ON pp.producto_id = p.id AND pp.es_principal = TRUE
    LEFT JOIN proveedor prov ON prov.id = pp.proveedor_id
WHERE p.activo = TRUE
    AND p.stock_actual <= p.stock_minimo
    AND p.es_servicio = FALSE;

-- Vista: Cuentas por cobrar vencidas
CREATE VIEW v_cuentas_vencidas AS
SELECT
    cpc.id,
    cl.nit,
    cl.nombre               AS cliente,
    cpc.numero_documento,
    cpc.fecha_emision,
    cpc.fecha_vencimiento,
    cpc.monto_original,
    cpc.saldo,
    DATEDIFF(CURRENT_DATE, cpc.fecha_vencimiento) AS dias_vencidos
FROM cuenta_por_cobrar cpc
    JOIN cliente cl         ON cl.id = cpc.cliente_id
WHERE cpc.estado IN ('PENDIENTE','PARCIAL')
    AND cpc.fecha_vencimiento < CURRENT_DATE;

-- Vista: Kardex de producto (movimientos)
CREATE VIEW v_kardex AS
SELECT
    ms.id,
    p.codigo_interno,
    p.nombre                AS producto,
    um.codigo               AS unidad,
    ms.tipo,
    ms.cantidad,
    ms.stock_anterior,
    ms.stock_nuevo,
    ms.costo_unitario,
    ms.referencia_tipo,
    ms.referencia_numero,
    ms.observacion,
    ms.fecha,
    u.nombre_completo       AS usuario,
    b.nombre                AS bodega
FROM movimiento_stock ms
    JOIN producto p         ON p.id = ms.producto_id
    JOIN unidad_medida um   ON um.id = p.unidad_medida_id
    JOIN usuario u          ON u.id = ms.usuario_id
    JOIN bodega b           ON b.id = ms.bodega_id;


-- ╔═══════════════════════════════════════════════════════════════════════════╗
-- ║  FIN DEL SCRIPT                                                         ║
-- ╚═══════════════════════════════════════════════════════════════════════════╝
-- Tablas:  47
-- Vistas:   4
-- Módulos: 15
--
-- NOTAS DE IMPLEMENTACIÓN:
--
-- 1. Los INSERT comentados son datos semilla; descomentar en primera
--    ejecución.
--
-- 2. Triggers de stock y costo promedio deben implementarse según
--    el motor elegido (la lógica debe vivir en la capa de aplicación
--    o en stored procedures, según la estrategia del equipo).
--
-- 3. PORTABILIDAD POR MOTOR:
--    PostgreSQL : AUTO_INCREMENT → SERIAL | BIGSERIAL
--                 BOOLEAN nativo
--                 TIMESTAMP → TIMESTAMPTZ
--                 TEXT nativo
--    SQL Server : AUTO_INCREMENT → IDENTITY(1,1)
--                 BOOLEAN → BIT
--                 TIMESTAMP → DATETIME2
--                 TEXT → NVARCHAR(MAX)
--                 DATEDIFF sintaxis distinta
--    MySQL      : Agregar ENGINE=InnoDB a cada CREATE TABLE
--                 BOOLEAN = TINYINT(1) internamente
--
-- 4. SEGURIDAD:
--    - password_hash: usar bcrypt/argon2, nunca texto plano
--    - fel_api_llave, fel_firma_password: cifrar en capa de aplicación
--    - Crear usuario de BD con permisos mínimos (no usar root)
--
-- 5. RESPALDO:
--    - Configurar backups automáticos diarios
--    - La tabla movimiento_stock es append-only; nunca borrar registros
--    - fel_log es append-only; conservar mínimo 5 años (Código Tributario)
--
-- =============================================================================